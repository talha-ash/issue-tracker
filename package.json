{
  "name": "issue-tracker",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "private": "true",
  "scripts": {
    "dev": "pnpm build:packages && concurrently -k -n ui,repo,backend,client,next,tan -c blue,green,cyan,cyan,yellow,red \"pnpm dev:ui\" \"pnpm dev:repo\" \"pnpm dev:backend\" \"pnpm dev:client\" \"pnpm dev:next\" \"pnpm dev:tan\"",
    "dev:ui": "pnpm --filter @issue-tracker/ui dev",
    "dev:repo": "pnpm --filter @issue-tracker/repo dev",
    "dev:backend": "pnpm --filter @issue-tracker/backend dev",
    "dev:client": "pnpm --filter @issue-tracker/client dev",
    "dev:next": "pnpm --filter @issue-tracker/next-app dev",
    "dev:tan": "pnpm --filter @issue-tracker/tanstart-app dev",
    "build": "pnpm -r build",
    "build:packages": "pnpm -r --filter \"./packages/*\" build",
    "build:apps": "pnpm -r --filter \"./apps/*\" build",
    "build:ui": "pnpm --filter @issue-tracker/ui build",
    "build:repo": "pnpm --filter @issue-tracker/repo build",
    "build:backend": "pnpm --filter @issue-tracker/backend build",
    "build:client": "pnpm --filter @issue-tracker/client build",
    "build:next": "pnpm --filter @issue-tracker/next-app build",
    "build:tan": "pnpm --filter @issue-tracker/tanstart-app build",
    "typecheck": "concurrently -n ui,repo,backend,client,next,tan -c blue,green,cyan,cyan,yellow,red \"pnpm typecheck:ui\" \"pnpm typecheck:repo\" \"pnpm typecheck:backend\" \"pnpm typecheck:client\" \"pnpm typecheck:next\" \"pnpm typecheck:tan\"",
    "typecheck:ui": "pnpm --filter @issue-tracker/ui typecheck",
    "typecheck:repo": "pnpm --filter @issue-tracker/repo typecheck",
    "typecheck:backend": "pnpm --filter @issue-tracker/backend typecheck",
    "typecheck:client": "pnpm --filter @issue-tracker/client typecheck",
    "typecheck:next": "pnpm --filter @issue-tracker/next-app typecheck",
    "typecheck:tan": "pnpm --filter @issue-tracker/tanstart-app typecheck",
    "lint": "pnpm -r lint",
    "lint:ui": "pnpm --filter @issue-tracker/ui lint",
    "lint:repo": "pnpm --filter @issue-tracker/repo lint",
    "lint:backend": "pnpm --filter @issue-tracker/backend lint",
    "lint:client": "pnpm --filter @issue-tracker/client lint",
    "lint:next": "pnpm --filter @issue-tracker/next-app lint",
    "lint:tan": "pnpm --filter @issue-tracker/tanstart-app lint",
    "test": "pnpm --filter @issue-tracker/tanstart-app test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .gitignore"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "volta": {
    "node": "22.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@tanstack/intent": "^0.0.29",
    "@tanstack/react-start": "^1.167.25",
    "@tanstack/start-client-core": "^1.167.11",
    "@tanstack/start-server-core": "^1.167.13",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "yaml": "^2.8.3"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.545.0",
    "neverthrow": "^8.2.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "server": "link:@clerk/tanstack-react-start/server",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.0.0",
    "vaul": "^1.1.2"
  }
}
