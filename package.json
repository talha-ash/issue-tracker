{
  "name": "issue-tracker",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "private": "true",
  "scripts": {
    "dev": "pnpm build:packages && concurrently -k -n ui,core,backend,next,tan -c blue,magenta,green,cyan,yellow \"pnpm dev:ui\" \"pnpm dev:core\" \"pnpm dev:backend\" \"pnpm dev:next\" \"pnpm dev:tan\"",
    "dev:ui": "pnpm --filter @issue-tracker/ui dev",
    "dev:core": "pnpm --filter @issue-tracker/core dev",
    "dev:backend": "pnpm --filter @issue-tracker/backend dev",
    "dev:next": "pnpm --filter @issue-tracker/next-app dev",
    "dev:tan": "pnpm --filter @issue-tracker/tanstart-app dev",
    "build": "pnpm -r build",
    "build:packages": "pnpm -r --filter \"./packages/*\" build",
    "build:apps": "pnpm -r --filter \"./apps/*\" build",
    "build:ui": "pnpm --filter @issue-tracker/ui build",
    "build:core": "pnpm --filter @issue-tracker/core build",
    "build:backend": "pnpm --filter @issue-tracker/backend build",
    "build:next": "pnpm --filter @issue-tracker/next-app build",
    "build:tan": "pnpm --filter @issue-tracker/tanstart-app build",
    "lint": "pnpm --filter @issue-tracker/next-app lint",
    "test": "pnpm --filter @issue-tracker/tanstart-app test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.2",
  "volta": {
    "node": "22.16.0"
  },
