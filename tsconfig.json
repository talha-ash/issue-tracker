{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "noEmit": true,
        "noImplicitAny": true,
        "allowJs": true,
        "strict": true,
        "allowSyntheticDefaultImports": true,
        "noUncheckedSideEffectImports": true,
        "incremental": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
    },
    "include": [
        "packages/**/src/**/*.ts",
        "packages/**/src/**/*.js",
        "packages/**/src/**/*.tsx",
        "packages/**/tests/**/*.ts",
        "packages/**/tests/**/*.js",
        "packages/**/tests/*/*.tsx",
        // "**/tailwind.config.js",
        // "**/postcss.config.cjs",
        "**/vite.config.ts",
    ],
    "exclude": [
        "**/assets/**/*",
        "node_modules",
        "dist"
    ]
}